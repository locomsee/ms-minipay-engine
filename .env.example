# Copy to .env (or set as real environment variables / platform secrets) for the `prod` profile.
# .env itself is gitignored - never commit real values.

SPRING_PROFILES_ACTIVE=prod

# JDBC connection details for the production PostgreSQL database
DB_URL=jdbc:postgresql://localhost:5432/minipay
DB_USERNAME=minipay
DB_PASSWORD=change-me

# HMAC signing key for JWTs - must be at least 256 bits (32+ characters)
JWT_SECRET=change-this-to-a-long-random-production-secret

# Optional: Railway/PaaS dynamic port (defaults to 8080 if unset)
PORT=8080
